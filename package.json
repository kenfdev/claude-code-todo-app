    "react-dom": "^19.1.0",
    "react-hook-form": "^7.57.0",
    "react-router": "^7.5.3",
    "zod": "^3.25.58"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.12",
    "@react-router/dev": "^7.5.3",
